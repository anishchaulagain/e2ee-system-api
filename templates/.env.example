# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to `.env` in your project root and fill in the values.
# NEVER commit the actual `.env` file — only this template.
#
# Usage: cp templates/.env.example .env
# =============================================================================

# ---- Application ----
NODE_ENV=development
PORT=3000
APP_NAME=my-app
LOG_LEVEL=debug                  # debug | info | warn | error

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# DATABASE_URL=mongodb://user:password@localhost:27017/mydb

# ---- Redis (cache / queue) ----
REDIS_URL=redis://localhost:6379

# ---- Authentication ----
JWT_SECRET=                      # Generate: openssl rand -base64 32
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- External APIs ----
# API_KEY=
# API_SECRET=

# ---- Email ----
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ---- Cloud / Storage ----
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=

# ---- Error Tracking ----
# SENTRY_DSN=

# ---- Feature Flags ----
# ENABLE_NEW_FEATURE=false
