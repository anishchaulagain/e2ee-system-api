# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed Users (seeded on startup if not exist)
SEED_USER1_USERNAME=alice
SEED_USER1_EMAIL=alice@e2ee.chat
SEED_USER1_PASSWORD=Alice@12345

SEED_USER2_USERNAME=bob
SEED_USER2_EMAIL=bob@e2ee.chat
SEED_USER2_PASSWORD=Bob@12345
